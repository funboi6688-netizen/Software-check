import React, { useState, useEffect } from 'react';
import { 
  Users, 
  Search, 
  UserCircle, 
  PlusCircle, 
  CheckCircle, 
  XCircle, 
  BookOpen, 
  LogOut, 
  LayoutDashboard,
  MapPin,
  ClipboardList
} from 'lucide-react';

/**
 * TUITION BRO - FRONTEND UI
 * Note: Includes Routing Logic and API interaction placeholders
 */

const App = () => {
  const [user, setUser] = useState(null); // Auth State
  const [view, setView] = useState('landing'); // 'landing', 'login', 'register', 'dashboard'
  const [role, setRole] = useState('tutor'); // Role selector for registration
  const [loading, setLoading] = useState(false);

  // Mock Data for UI
  const [posts] = useState([
    { id: 1, title: 'Need Grade 10 Math Tutor', area: 'Dhaka', subject: 'Math', salary: '5000', guardian: 'Mr. Rahim' },
    { id: 2, title: 'Physics Tutor for A-Levels', area: 'Chittagong', subject: 'Physics', salary: '8000', guardian: 'Ms. Karim' },
  ]);

  const handleLogin = (e) => {
    e.preventDefault();
    // Simulate API Login
    setUser({ name: "Demo User", role: role, id: 1 });
    setView('dashboard');
  };

  const handleLogout = () => {
    setUser(null);
    setView('landing');
  };

  // --- Components ---

  const Navbar = () => (
    <nav className="bg-white border-b px-6 py-4 flex justify-between items-center sticky top-0 z-50">
      <div className="flex items-center gap-2 cursor-pointer" onClick={() => setView('landing')}>
        <div className="bg-blue-600 p-2 rounded-lg text-white">
          <BookOpen size={24} />
        </div>
        <span className="text-xl font-bold text-gray-800">Tuition Bro</span>
      </div>
      <div className="flex items-center gap-4">
        {user ? (
          <>
            <span className="text-sm font-medium text-gray-600">Hi, {user.name}</span>
            <button onClick={handleLogout} className="text-red-500 flex items-center gap-1 hover:bg-red-50 px-3 py-1.5 rounded-md transition">
              <LogOut size={18} /> Logout
            </button>
          </>
        ) : (
          <button onClick={() => setView('login')} className="bg-blue-600 text-white px-5 py-2 rounded-lg font-semibold hover:bg-blue-700 transition">
            Login
          </button>
        )}
      </div>
    </nav>
  );

  const TutorDashboard = () => (
    <div className="space-y-6">
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {/* Profile Stats */}
