          <div className="flex flex-col items-center text-center">
            <div className="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center text-blue-600 mb-4">
              <UserCircle size={48} />
            </div>
            <h3 className="text-xl font-bold">Profile Status</h3>
            <span className="mt-2 px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-bold uppercase tracking-wider">Pending Verification</span>
          </div>
          <div className="mt-6 space-y-4">
            <button className="w-full bg-blue-50 text-blue-600 py-2 rounded-lg font-semibold">Edit Education Info</button>
            <button className="w-full border py-2 rounded-lg text-gray-600">Upload New CV</button>
          </div>
        </div>

        {/* Job Listings */}
        <div className="md:col-span-2 space-y-4">
          <h2 className="text-xl font-bold flex items-center gap-2"><ClipboardList className="text-blue-600" /> Matching Tuition Posts</h2>
          {posts.map(post => (
            <div key={post.id} className="bg-white p-5 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition group">
              <div className="flex justify-between items-start">
                <div>
                  <h4 className="font-bold text-lg group-hover:text-blue-600 transition">{post.title}</h4>
                  <div className="flex items-center gap-3 text-sm text-gray-500 mt-1">
                    <span className="flex items-center gap-1"><MapPin size={14}/> {post.area}</span>
                    <span>•</span>
                    <span className="font-medium text-gray-700">{post.subject}</span>
                  </div>
                </div>
                <div className="text-right">
                  <span className="block text-blue-600 font-bold">BDT {post.salary}</span>
                  <span className="text-xs text-gray-400">By {post.guardian}</span>
                </div>
              </div>
              <button className="mt-4 w-full bg-gray-50 text-gray-700 py-2 rounded-lg font-semibold hover:bg-blue-600 hover:text-white transition">Apply for this post</button>
            </div>
