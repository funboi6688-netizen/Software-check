              <h2 className="text-2xl font-bold">{view === 'login' ? 'Welcome Back' : 'Join Tuition Bro'}</h2>
              <p className="text-sm text-gray-500 mt-1">
                {view === 'login' ? 'Enter your credentials to continue' : 'Sign up to start your journey'}
