            </div>
            
            <form onSubmit={handleLogin} className="space-y-4">
              {view === 'register' && (
                <div>
                  <label className="text-sm font-semibold text-gray-700">Full Name</label>
                  <input className="w-full mt-1 p-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500" placeholder="John Doe" />
                </div>
              )}
              <div>
                <label className="text-sm font-semibold text-gray-700">Email Address</label>
                <input type="email" className="w-full mt-1 p-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500" placeholder="name@email.com" />
              </div>
              <div>
                <label className="text-sm font-semibold text-gray-700">Password</label>
                <input type="password" placeholder="••••••••" className="w-full mt-1 p-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-blue-500" />
              </div>
              
              <div className="flex gap-2 mt-2">
                <button 
                  type="button"
                  onClick={() => setRole('tutor')}
                  className={`flex-1 py-2 text-xs font-bold rounded-lg border transition ${role === 'tutor' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-400 border-gray-200'}`}
                >TUTOR</button>
                <button 
                  type="button"
                  onClick={() => setRole('guardian')}
                  className={`flex-1 py-2 text-xs font-bold rounded-lg border transition ${role === 'guardian' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-400 border-gray-200'}`}
                >GUARDIAN</button>
              </div>

              <button className="w-full bg-blue-600 text-white py-3 rounded-xl font-bold mt-6 shadow-lg shadow-blue-100 hover:bg-blue-700 transition">
                {view === 'login' ? 'Sign In' : 'Create Account'}
              </button>
            </form>

            <div className="mt-6 text-center text-sm">
              <span className="text-gray-500">{view === 'login' ? "Don't have an account?" : "Already have an account?"}</span>
              <button onClick={() => setView(view === 'login' ? 'register' : 'login')} className="ml-1 text-blue-600 font-bold hover:underline">
                {view === 'login' ? 'Sign Up' : 'Login'}
              </button>
            </div>
            
            <button onClick={() => {setUser({name: 'Admin', role: 'admin'}); setView('dashboard')}} className="mt-8 w-full text-xs text-gray-300 hover:text-gray-500 transition">
              Quick Admin Login (Demo)
            </button>
          </div>
        )}

        {view === 'dashboard' && user && (
          <div className="space-y-6">
            <div className="flex items-center gap-3 border-b pb-6">
              <div className="bg-blue-600 p-2 rounded-lg text-white">
                <LayoutDashboard size={20} />
              </div>
              <div>
                <h1 className="text-2xl font-bold capitalize">{user.role} Dashboard</h1>
                <p className="text-sm text-gray-500 font-medium">Manage your activities and profile</p>
              </div>
            </div>
            {user.role === 'tutor' && <TutorDashboard />}
            {user.role === 'guardian' && <GuardianDashboard />}
            {user.role === 'admin' && <AdminDashboard />}
