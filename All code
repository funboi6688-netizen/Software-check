            <p className="text-gray-500 text-lg max-w-2xl mx-auto">
              Join thousands of students and professional tutors. Find the perfect match for your educational journey today.
            </p>
            <div className="flex justify-center gap-4 pt-6">
              <button onClick={() => {setRole('tutor'); setView('register')}} className="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:shadow-blue-200 transition">Become a Tutor</button>
