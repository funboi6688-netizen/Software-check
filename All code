          <PlusCircle size={20} /> Create New Post
        </button>
      </div>
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div className="bg-white p-6 rounded-xl border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-gray-400 h-48">
          <p>You have no active posts.</p>
          <p className="text-xs">Create one to start finding tutors.</p>
        </div>
      </div>
    </div>
  );

  const AdminDashboard = () => (
    <div className="space-y-6">
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        {[
          { label: 'Pending Tutors', count: '12', color: 'bg-yellow-500' },
          { label: 'Active Guardians', count: '45', color: 'bg-blue-500' },
          { label: 'Total Posts', count: '89', color: 'bg-green-500' },
          { label: 'Reports', count: '3', color: 'bg-red-500' },
        ].map(card => (
          <div key={card.label} className="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p className="text-gray-500 text-sm font-medium">{card.label}</p>
            <h4 className="text-2xl font-bold mt-1">{card.count}</h4>
            <div className={`h-1 w-12 ${card.color} mt-3 rounded-full`}></div>
          </div>
        ))}
      </div>

      <div className="bg-white border rounded-xl overflow-hidden shadow-sm">
        <div className="p-4 border-b bg-gray-50 font-bold text-gray-700 uppercase text-xs tracking-wider">Tutor Approval Queue</div>
        <table className="w-full text-left">
          <thead className="bg-gray-50 text-gray-500 text-sm">
