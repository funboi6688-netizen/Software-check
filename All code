          </thead>
          <tbody className="divide-y text-sm">
            {[1, 2, 3].map(i => (
              <tr key={i} className="hover:bg-gray-50">
                <td className="p-4 font-medium text-gray-900">Applicant {i}</td>
                <td className="p-4">Dhaka</td>
                <td className="p-4">{i + 2} Years</td>
                <td className="p-4 flex gap-2">
                  <button className="text-green-600 hover:bg-green-50 p-1 rounded-md transition"><CheckCircle size={20}/></button>
                  <button className="text-red-600 hover:bg-red-50 p-1 rounded-md transition"><XCircle size={20}/></button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
